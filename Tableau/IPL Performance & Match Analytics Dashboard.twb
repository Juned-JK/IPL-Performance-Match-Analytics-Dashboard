    <worksheet name='Most Sixes and Fours and strike rate'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Tableau Bold' fontsize='16'>Power Hitters - Sixes, Fours &amp; Strike Rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='IPL' name='federated.0gfzi02028b6xu13lmqn81hukpde' />
          </datasources>
          <datasource-dependencies datasource='federated.0gfzi02028b6xu13lmqn81hukpde'>
            <column caption='Total Sixes' datatype='integer' name='[Calculation_0611622126985216]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;    IF [runs_batter] = 6 THEN 1&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='Total Fours' datatype='integer' name='[Calculation_0611622127685633]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [runs_batter] = 4 THEN 1 ELSE 0 END&#13;&#10;)' />
            </column>
            <column caption='strike rate (100 balls faced)' datatype='real' name='[Calculation_0611622135025669]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([balls_faced]) &gt;= 100 Then((SUM([runs_batter])/SUM([balls_faced]))*100) END' />
            </column>
            <column caption='Balls Faced' datatype='integer' name='[balls_faced]' role='measure' type='quantitative' />
            <column caption='Batter' datatype='string' name='[batter]' role='dimension' type='nominal' />
            <column caption='Batting Team' datatype='string' name='[batting_team]' role='dimension' type='nominal' />
            <column caption='Bowler' datatype='string' name='[bowler]' role='dimension' type='nominal' />
