      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0gfzi02028b6xu13lmqn81hukpde].[usr:Calculation_0611622135025669:qk]&quot;' value='strike rate' />
        </aliases>
      </column>
      <column caption='Total Sixes' datatype='integer' name='[Calculation_0611622126985216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [runs_batter] = 6 THEN 1&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Total Fours' datatype='integer' name='[Calculation_0611622127685633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [runs_batter] = 4 THEN 1 ELSE 0 END&#13;&#10;)' />
      </column>
      <column caption='win percentage' datatype='real' name='[Calculation_0611622130913283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNTD(&#13;&#10;IF [match_won_by] = [batting_team] THEN [match_id] END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([match_id])) * 100' />
      </column>
      <column caption='strike rate (100 balls faced)' datatype='real' name='[Calculation_0611622135025669]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([balls_faced]) &gt;= 100 Then((SUM([runs_batter])/SUM([balls_faced]))*100) END' />
      </column>
      <column caption='wins by team' datatype='integer' name='[Calculation_0611622145794058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [batting_team] = [match_won_by]&#13;&#10;THEN [match_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Team inning score' datatype='integer' name='[Calculation_0611622147342347]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [batting_team], [match_id], [innings] : MAX([team_runs]) }' />
      </column>
      <column caption='Highest Team Score' datatype='integer' name='[Calculation_0611622148128780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [batting_team] : MAX([Calculation_0611622147342347]) }' />
      </column>
      <column caption='IPL.csv' datatype='table' name='[__tableau_internal_object_id__].[IPL.csv_7444F91080074C558A44D4E0BC1ABABC]' role='measure' type='quantitative' />
      <column caption='Ball' datatype='integer' name='[ball]' role='measure' type='quantitative' />
