            <column-instance column='[year]' derivation='None' name='[none:year:qk]' pivot='key' type='quantitative' />
            <column caption='Runs Batter' datatype='integer' name='[runs_batter]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Season' datatype='integer' name='[season]' role='dimension' type='ordinal' />
            <column-instance column='[balls_faced]' derivation='Sum' name='[sum:balls_faced:qk]' pivot='key' type='quantitative' />
            <column-instance column='[runs_batter]' derivation='Sum' name='[sum:runs_batter:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0611622126985216]' derivation='User' name='[usr:Calculation_0611622126985216:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0611622127685633]' derivation='User' name='[usr:Calculation_0611622127685633:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0611622135025669]' derivation='User' name='[usr:Calculation_0611622135025669:qk]' pivot='key' type='quantitative' />
            <column caption='Venue' datatype='string' name='[venue]' role='dimension' type='nominal' />
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
          </datasource-dependencies>
